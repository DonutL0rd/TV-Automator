# TV-Automator Environment Variables
# Copy to .env and fill in your values

# ── MLB.TV credentials ───────────────────────────────────────────
# If set, the app will auto-login on startup and when you click
# the Login button in the dashboard.
# MLB_USERNAME=you@example.com
# MLB_PASSWORD=yourpassword

# ── Display / browser ────────────────────────────────────────────
# DISPLAY=:0
# CHROME_PATH=/usr/bin/google-chrome

# ── Data directory ───────────────────────────────────────────────
# DATA_DIR=/data
